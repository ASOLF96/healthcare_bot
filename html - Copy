<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MedAssist AI - Healthcare Bot</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-primary: #f8fafb;
            --bg-secondary: #ffffff;
            --bg-tertiary: #e8f0f2;
            --fg-primary: #1a2f38;
            --fg-secondary: #4a6572;
            --fg-muted: #7a9199;
            --accent-primary: #0d9488;
            --accent-secondary: #14b8a6;
            --accent-light: #ccfbf1;
            --emergency: #dc2626;
            --warning: #f59e0b;
            --success: #10b981;
            --card-shadow: 0 4px 24px rgba(13, 148, 136, 0.08);
            --border-color: #d1e3e7;
        }

        .dark {
            --bg-primary: #0f1a1d;
            --bg-secondary: #162227;
            --bg-tertiary: #1d2f35;
            --fg-primary: #e8f4f6;
            --fg-secondary: #a3c4ca;
            --fg-muted: #6a8f98;
            --accent-primary: #14b8a6;
            --accent-secondary: #2dd4bf;
            --accent-light: #134e4a;
            --card-shadow: 0 4px 24px rgba(0, 0, 0, 0.3);
            --border-color: #2a4249;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--bg-primary);
            color: var(--fg-primary);
            min-height: 100vh;
            transition: background 0.3s ease, color 0.3s ease;
        }

        h1, h2, h3, h4, h5, h6 {
            font-family: 'Space Grotesk', sans-serif;
        }

        .bg-pattern {
            background-image: 
                radial-gradient(circle at 20% 20%, rgba(13, 148, 136, 0.05) 0%, transparent 50%),
                radial-gradient(circle at 80% 80%, rgba(13, 152, 140, 0.03) 0%, transparent 50%),
                url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%230d9488' fill-opacity='0.03'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
        }

        .glass-card {
            background: var(--bg-secondary);
            border: 1px solid var(--border-color);
            box-shadow: var(--card-shadow);
            backdrop-filter: blur(10px);
        }

        .accent-gradient {
            background: linear-gradient(135deg, var(--accent-primary) 0%, #0f766e 100%);
        }

        .chat-bubble-user {
            background: linear-gradient(135deg, var(--accent-primary) 0%, var(--accent-secondary) 100%);
            color: white;
        }

        .chat-bubble-bot {
            background: var(--bg-tertiary);
            color: var(--fg-primary);
        }

        .pulse-ring {
            animation: pulse-ring 2s cubic-bezier(0.455, 0.03, 0.515, 0.955) infinite;
        }

        @keyframes pulse-ring {
            0% { transform: scale(0.8); opacity: 1; }
            50% { transform: scale(1.2); opacity: 0.5; }
            100% { transform: scale(0.8); opacity: 1; }
        }

        .float-animation {
            animation: float 6s ease-in-out infinite;
        }

        @keyframes float {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-10px); }
        }

        .slide-up {
            animation: slideUp 0.5s ease-out forwards;
        }

        @keyframes slideUp {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .fade-in {
            animation: fadeIn 0.3s ease-out forwards;
        }

        @keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }

        .typing-indicator span {
            animation: typing 1.4s infinite ease-in-out;
        }

        .typing-indicator span:nth-child(2) { animation-delay: 0.2s; }
        .typing-indicator span:nth-child(3) { animation-delay: 0.4s; }

        @keyframes typing {
            0%, 60%, 100% { transform: translateY(0); }
            30% { transform: translateY(-4px); }
        }

        .btn-primary {
            background: linear-gradient(135deg, var(--accent-primary) 0%, #0f766e 100%);
            color: white;
            transition: all 0.3s ease;
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(13, 148, 136, 0.3);
        }

        .btn-primary:active {
            transform: translateY(0);
        }

        .symptom-tag {
            transition: all 0.2s ease;
        }

        .symptom-tag:hover {
            transform: scale(1.05);
        }

        .symptom-tag.selected {
            background: var(--accent-primary);
            color: white;
            border-color: var(--accent-primary);
        }

        .scrollbar-thin::-webkit-scrollbar {
            width: 6px;
        }

        .scrollbar-thin::-webkit-scrollbar-track {
            background: var(--bg-tertiary);
            border-radius: 3px;
        }

        .scrollbar-thin::-webkit-scrollbar-thumb {
            background: var(--accent-primary);
            border-radius: 3px;
        }

        .nav-item {
            position: relative;
            transition: all 0.3s ease;
        }

        .nav-item::after {
            content: '';
            position: absolute;
            bottom: -2px;
            left: 50%;
            width: 0;
            height: 2px;
            background: var(--accent-primary);
            transition: all 0.3s ease;
            transform: translateX(-50%);
        }

        .nav-item:hover::after, .nav-item.active::after {
            width: 100%;
        }

        .emergency-btn {
            animation: emergencyPulse 2s infinite;
        }

        @keyframes emergencyPulse {
            0%, 100% { box-shadow: 0 0 0 0 rgba(220, 38, 38, 0.4); }
            50% { box-shadow: 0 0 0 15px rgba(220, 38, 38, 0); }
        }

        .stat-card {
            transition: all 0.3s ease;
        }

        .stat-card:hover {
            transform: translateY(-4px);
        }

        #map {
            height: 300px;
            border-radius: 12px;
            z-index: 1;
        }

        @media (prefers-reduced-motion: reduce) {
            *, *::before, *::after {
                animation-duration: 0.01ms !important;
                animation-iteration-count: 1 !important;
                transition-duration: 0.01ms !important;
            }
        }

        .voice-btn.listening {
            background: var(--emergency);
            animation: voicePulse 1s infinite;
        }

        @keyframes voicePulse {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.1); }
        }

        .progress-ring {
            transform: rotate(-90deg);
        }

        .hospital-card {
            transition: all 0.3s ease;
        }

        .hospital-card:hover {
            border-color: var(--accent-primary);
            background: var(--bg-tertiary);
        }
        </style>
        </head>
<body class="bg-pattern">
    <!-- Emergency Modal -->
    <div id="emergencyModal" class="fixed inset-0 z-50 hidden items-center justify-center p-4" style="background: rgba(0,0,0,0.8); backdrop-filter: blur(8px);">
        <div class="glass-card rounded-2xl p-8 max-w-md w-full text-center slide-up">
            <div class="w-20 h-20 rounded-full bg-red-500/20 flex items-center justify-center mx-auto mb-6">
                <svg class="w-10 h-10 text-red-500 pulse-ring" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
                </svg>
            </div>
            <h2 class="text-2xl font-bold mb-2" style="color: var(--fg-primary);">Emergency Mode Active</h2>
            <p class="mb-6" style="color: var(--fg-secondary);">Finding nearest emergency services...</p>
            <div id="emergencyHospitals" class="space-y-3 mb-6 max-h-48 overflow-y-auto"></div>
            <div class="flex gap-3 justify-center">
                <a href="tel:108" class="flex-1 py-3 px-4 rounded-xl bg-red-500 text-white font-semibold flex items-center justify-center gap-2 hover:bg-red-600 transition-all">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
                    </svg>
                    Call Ambulance
                </a>
                <button onclick="closeEmergency()" class="py-3 px-6 rounded-xl border font-semibold transition-all hover:bg-gray-100 dark:hover:bg-gray-800" style="border-color: var(--border-color); color: var(--fg-secondary);">Close</button>
            </div>
        </div>
    </div>

    <!-- Main App -->
    <div id="app" class="min-h-screen">
        <!-- Auth Screen -->
        <div id="authScreen" class="min-h-screen flex items-center justify-center p-4">
            <div class="glass-card rounded-3xl p-8 md:p-12 max-w-md w-full slide-up">
                <!-- Logo -->
                <div class="flex items-center justify-center mb-8">
                    <div class="w-16 h-16 rounded-2xl accent-gradient flex items-center justify-center float-animation">
                        <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
                        </svg>
                    </div>
                </div>
                
                <h1 class="text-3xl font-bold text-center mb-2" style="color: var(--fg-primary);">MedAssist AI</h1>
                <p class="text-center mb-8" style="color: var(--fg-muted);">Your intelligent healthcare companion</p>

                <!-- Auth Tabs -->
                <div class="flex mb-6 p-1 rounded-xl" style="background: var(--bg-tertiary);">
                    <button id="loginTab" onclick="switchAuthTab('login')" class="flex-1 py-2 px-4 rounded-lg font-medium transition-all" style="background: var(--accent-primary); color: white;">Login</button>
                    <button id="registerTab" onclick="switchAuthTab('register')" class="flex-1 py-2 px-4 rounded-lg font-medium transition-all" style="color: var(--fg-muted);">Register</button>
                </div>

                <!-- Login Form -->
                <form id="loginForm" onsubmit="handleLogin(event)" class="space-y-4">
                    <div>
                        <label class="block text-sm font-medium mb-2" style="color: var(--fg-secondary);">Email</label>
                        <input type="email" id="loginEmail" required class="w-full px-4 py-3 rounded-xl border transition-all focus:outline-none focus:ring-2 focus:ring-teal-500" style="background: var(--bg-tertiary); border-color: var(--border-color); color: var(--fg-primary);" placeholder="Enter your email">
                    </div>
                    <div>
                        <label class="block text-sm font-medium mb-2" style="color: var(--fg-secondary);">Password</label>
                        <input type="password" id="loginPassword" required class="w-full px-4 py-3 rounded-xl border transition-all focus:outline-none focus:ring-2 focus:ring-teal-500" style="background: var(--bg-tertiary); border-color: var(--border-color); color: var(--fg-primary);" placeholder="Enter your password">
                    </div>
                    <button type="submit" class="w-full py-3 rounded-xl btn-primary font-semibold">Sign In</button>
                </form>

                <!-- Register Form -->
                <form id="registerForm" onsubmit="handleRegister(event)" class="space-y-4 hidden">
                    <div>
                        <label class="block text-sm font-medium mb-2" style="color: var(--fg-secondary);">Full Name</label>
                        <input type="text" id="regName" required class="w-full px-4 py-3 rounded-xl border transition-all focus:outline-none focus:ring-2 focus:ring-teal-500" style="background: var(--bg-tertiary); border-color: var(--border-color); color: var(--fg-primary);" placeholder="Enter your name">
                    </div>
                    <div>
                        <label class="block text-sm font-medium mb-2" style="color: var(--fg-secondary);">Email</label>
                        <input type="email" id="regEmail" required class="w-full px-4 py-3 rounded-xl border transition-all focus:outline-none focus:ring-2 focus:ring-teal-500" style="background: var(--bg-tertiary); border-color: var(--border-color); color: var(--fg-primary);" placeholder="Enter your email">
                    </div>
                    <div>
                        <label class="block text-sm font-medium mb-2" style="color: var(--fg-secondary);">Password</label>
                        <input type="password" id="regPassword" required class="w-full px-4 py-3 rounded-xl border transition-all focus:outline-none focus:ring-2 focus:ring-teal-500" style="background: var(--bg-tertiary); border-color: var(--border-color); color: var(--fg-primary);" placeholder="Create a password">
                    </div>
                    <div>
                        <label class="block text-sm font-medium mb-2" style="color: var(--fg-secondary);">Preferred Language</label>
                        <select id="regLanguage" class="w-full px-4 py-3 rounded-xl border transition-all focus:outline-none focus:ring-2 focus:ring-teal-500" style="background: var(--bg-tertiary); border-color: var(--border-color); color: var(--fg-primary);">
                            <option value="en">English</option>
                            <option value="hi">Hindi</option>
                            <option value="te">Telugu</option>
                        </select>
                    </div>
                    <button type="submit" class="w-full py-3 rounded-xl btn-primary font-semibold">Create Account</button>
                </form>

                <!-- Demo Access -->
                <button onclick="demoLogin()" class="w-full mt-4 py-3 rounded-xl border font-medium transition-all hover:bg-teal-50 dark:hover:bg-teal-900/20" style="border-color: var(--accent-primary); color: var(--accent-primary);">
                    Try Demo Mode
                </button>
            </div>
        </div>

        <!-- Main Dashboard -->
        <div id="dashboardScreen" class="hidden">
            <!-- Header -->
            <header class="sticky top-0 z-40 glass-card border-b" style="border-color: var(--border-color);">
                <div class="max-w-7xl mx-auto px-4 py-3">
                    <div class="flex items-center justify-between">
                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10 rounded-xl accent-gradient flex items-center justify-center">
                                <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
                                </svg>
                            </div>
                            <div>
                                <h1 class="font-bold text-lg" style="color: var(--fg-primary);">MedAssist AI</h1>
                                <p class="text-xs" style="color: var(--fg-muted);">Healthcare Assistant</p>
                            </div>
                        </div>

                        <!-- Navigation -->
                        <nav class="hidden md:flex items-center gap-6">
                            <button onclick="switchView('chat')" class="nav-item py-2 font-medium active" style="color: var(--fg-primary);">Chat</button>
                            <button onclick="switchView('symptoms')" class="nav-item py-2 font-medium" style="color: var(--fg-secondary);">Symptoms</button>
                            <button onclick="switchView('hospitals')" class="nav-item py-2 font-medium" style="color: var(--fg-secondary);">Hospitals</button>
                            <button onclick="switchView('history')" class="nav-item py-2 font-medium" style="color: var(--fg-secondary);">History</button>
                        </nav>

                        <div class="flex items-center gap-3">
                            <!-- Language Selector -->
                            <select id="languageSelect" onchange="changeLanguage(this.value)" class="px-3 py-2 rounded-lg border text-sm transition-all" style="background: var(--bg-tertiary); border-color: var(--border-color); color: var(--fg-primary);">
                                <option value="en">EN</option>
                                <option value="hi">HI</option>
                                <option value="te">TE</option>
                            </select>

                            <!-- Theme Toggle -->
                            <button onclick="toggleTheme()" class="p-2 rounded-lg border transition-all hover:bg-gray-100 dark:hover:bg-gray-800" style="border-color: var(--border-color);" aria-label="Toggle theme">
                                <svg id="sunIcon" class="w-5 h-5 hidden" style="color: var(--fg-primary);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"></path>
                                </svg>
                                <svg id="moonIcon" class="w-5 h-5" style="color: var(--fg-primary);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path>
                                </svg>
                            </button>

                            <!-- User Menu -->
                            <div class="relative">
                                <button onclick="toggleUserMenu()" class="flex items-center gap-2 p-2 rounded-lg border transition-all hover:bg-gray-100 dark:hover:bg-gray-800" style="border-color: var(--border-color);">
                                    <div class="w-8 h-8 rounded-full accent-gradient flex items-center justify-center text-white font-semibold text-sm" id="userAvatar">U</div>
                                    <svg class="w-4 h-4 hidden md:block" style="color: var(--fg-muted);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                                    </svg>
                                </button>
                                <div id="userMenu" class="absolute right-0 top-full mt-2 w-48 glass-card rounded-xl py-2 hidden fade-in">
                                    <div class="px-4 py-2 border-b" style="border-color: var(--border-color);">
                                        <p class="font-medium" style="color: var(--fg-primary);" id="userName">User</p>
                                        <p class="text-sm" style="color: var(--fg-muted);" id="userEmail">user@email.com</p>
                                    </div>
                                    <button onclick="switchView('profile')" class="w-full px-4 py-2 text-left hover:bg-gray-100 dark:hover:bg-gray-800 transition-all" style="color: var(--fg-secondary);">Profile Settings</button>
                                    <button onclick="handleLogout()" class="w-full px-4 py-2 text-left hover:bg-gray-100 dark:hover:bg-gray-800 transition-all text-red-500">Logout</button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Mobile Navigation -->
                    <nav class="flex md:hidden items-center gap-2 mt-3 overflow-x-auto pb-2">
                        <button onclick="switchView('chat')" class="mobile-nav-item px-4 py-2 rounded-lg font-medium whitespace-nowrap transition-all" style="background: var(--accent-primary); color: white;">Chat</button>
                        <button onclick="switchView('symptoms')" class="mobile-nav-item px-4 py-2 rounded-lg font-medium whitespace-nowrap transition-all" style="background: var(--bg-tertiary); color: var(--fg-secondary);">Symptoms</button>
                        <button onclick="switchView('hospitals')" class="mobile-nav-item px-4 py-2 rounded-lg font-medium whitespace-nowrap transition-all" style="background: var(--bg-tertiary); color: var(--fg-secondary);">Hospitals</button>
                        <button onclick="switchView('history')" class="mobile-nav-item px-4 py-2 rounded-lg font-medium whitespace-nowrap transition-all" style="background: var(--bg-tertiary); color: var(--fg-secondary);">History</button>
                    </nav>
                </div>
            </header>

            <!-- Main Content Area -->
            <main class="max-w-7xl mx-auto px-4 py-6">
                <!-- Chat View -->
                <div id="chatView" class="view">
                    <div class="grid lg:grid-cols-3 gap-6">
                        <!-- Chat Area -->
                        <div class="lg:col-span-2 glass-card rounded-2xl overflow-hidden flex flex-col" style="height: calc(100vh - 200px); min-height: 500px;">
                            <!-- Chat Header -->
                            <div class="p-4 border-b flex items-center justify-between" style="border-color: var(--border-color);">
                                <div class="flex items-center gap-3">
                                    <div class="w-10 h-10 rounded-full accent-gradient flex items-center justify-center">
                                        <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                                        </svg>
                                    </div>
                                    <div>
                                        <h3 class="font-semibold" style="color: var(--fg-primary);">AI Health Assistant</h3>
                                        <p class="text-xs flex items-center gap-1" style="color: var(--success);">
                                            <span class="w-2 h-2 rounded-full bg-green-500"></span>
                                            Online
                                        </p>
                                    </div>
                                </div>
                                <button onclick="clearChat()" class="p-2 rounded-lg border transition-all hover:bg-gray-100 dark:hover:bg-gray-800" style="border-color: var(--border-color);" aria-label="Clear chat">
                                    <svg class="w-5 h-5" style="color: var(--fg-muted);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                                    </svg>
                                </button>
                            </div>

                            <!-- Chat Messages -->
                            <div id="chatMessages" class="flex-1 overflow-y-auto p-4 space-y-4 scrollbar-thin">
                                <!-- Welcome Message -->
                                <div class="flex gap-3 fade-in">
